[user]
	name = Mieszko Boczkowski
	email = mieszko@bosper.pl
[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[color]
	ui = auto
[rebase]
	autosquash = true
[push]
	autoSetupRemote = true
[alias]
	a = add
	aa = add --all
	c = commit
	ca = commit --all
	cam = commit --all --message
	cand = commit --all --no-edit --amend
	cnd = commit --no-edit --ammend
	f = fetch
	fixup = "! git commit --fixup $(git log -n 1 --format="%h" --invert-grep --grep='^fixup! ')"
	l = pull
	p = push
	pf = push --force-with-lease --force-if-includes
	plog = log --oneline --decorate
	graph = log --oneline --decorate --graph --all
	pplog = log --graph --pretty='%Cred%h%Creset -%C(auto)%d%Creset %s %Cgreen(%ar) %C(bold blue)<%an>%Creset'
	pplogd = log --graph --pretty='%Cred%h%Creset -%C(auto)%d%Creset %s %Cgreen(%ad) %C(bold blue)<%an>%Creset' --date=short
	quickfix = "! git add --all && git fixup && git push --force"
	st = status
	sw = switch
